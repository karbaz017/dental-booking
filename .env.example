# PostgreSQL — use any reachable server (Docker, Homebrew, Postgres.app, cloud).
#
# Docker (docker-compose.yml defaults):
#   postgresql://postgres:postgres@localhost:5432/dental_booking
#
# Homebrew Postgres on Mac (typical: your macOS username, no password, TCP):
#   postgresql://YOUR_USERNAME@127.0.0.1:5432/dental_booking
# Create DB once: `createdb dental_booking` (or `psql postgres -c 'CREATE DATABASE dental_booking;'`)
#
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dental_booking"
DATABASE_URL="postgresql://arbaz@127.0.0.1:5432/dental_booking"

# Auth.js / NextAuth — use `openssl rand -base64 32` in production
AUTH_SECRET="replace-with-a-long-random-string-for-local-dev"

# Required for /staff/register
STAFF_REGISTRATION_CODE="replace-with-internal-staff-code"

# Optional: protect GET/POST /api/cron/reminders in production (Authorization: Bearer <value>)
# CRON_SECRET=""

# Optional: send reminder emails via Resend (https://resend.com)
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="DentalCare <onboarding@resend.dev>"
